      "Glob(**)",
      "Grep(**)",
      "SemanticSearch(**)",
      "Shell(terraform fmt*)",
      "Shell(terraform init*)",
      "Shell(terraform plan*)",
      "Shell(terraform validate*)",
      "Shell(terraform state*)",
      "Shell(terraform output*)",
      "Shell(terraform apply*)",
      "Shell(az *)",
